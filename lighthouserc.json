{
  "ci": {
    "collect": {
      "startServerCommand": "npm run serve:lighthouse",
      "startServerReadyPattern": "Ready",
      "startServerReadyTimeout": 240000,
      "numberOfRuns": 2,
      "settings": {
        "preset": "desktop",
        "formFactor": "desktop",
        "throttlingMethod": "provided"
      },
      "url": [
        "http://127.0.0.1:3001/",
        "http://127.0.0.1:3001/reviews",
        "http://127.0.0.1:3001/tools"
      ]
    },
    "assert": {
      "assertions": {
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "max-potential-fid": ["error", { "maxNumericValue": 200 }],
        "interactive": ["error", { "maxNumericValue": 4000 }],
        "total-byte-weight": ["error", { "maxNumericValue": 2200000 }]
      }
    }
  }
}
