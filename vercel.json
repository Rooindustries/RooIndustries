{
  "framework": "nextjs",
  "functions": {
    "app/api/admin/commerce-readiness/route.js": {
      "regions": ["dub1"]
    },
    "app/api/bookingAvailability/route.js": {
      "regions": ["dub1"]
    },
    "app/api/holdSlot/route.js": {
      "regions": ["dub1"]
    },
    "app/api/releaseHold/route.js": {
      "regions": ["dub1"]
    },
    "app/api/payment/**/*": {
      "regions": ["dub1"]
    },
    "app/api/razorpay/**/*": {
      "regions": ["dub1"]
    },
    "app/api/ref/**/*": {
      "regions": ["dub1"]
    },
    "app/api/tourney/**/*": {
      "regions": ["dub1"]
    },
    "app/api/admin/tourney-*/route.js": {
      "regions": ["dub1"]
    },
    "app/tourney/**/*": {
      "regions": ["dub1"]
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "rooindustries.com"
        }
      ],
      "destination": "https://www.rooindustries.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "x-vercel-cdn-cache-control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        },
        {
          "key": "Link",
          "value": "</fonts/manrope-latin-variable.woff2>; rel=preload; as=font; type=font/woff2; crossorigin, </favicon-96x96.png>; rel=preload; as=image"
        }
      ]
    },
    {
      "source": "/static/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/:path*.:ext(png|jpg|jpeg|gif|webp|avif|svg|ico|woff2|woff|ttf|otf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/payment/reconcile",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/ref/cronSyncAll",
      "schedule": "*/10 * * * *"
    }
  ]
}
