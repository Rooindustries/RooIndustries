{
  "name": "serviport",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@fontsource-variable/roboto-flex": "^5.2.8",
    "@formspree/react": "^3.0.0",
    "@paypal/react-paypal-js": "^8.9.2",
    "@portabletext/react": "^4.0.3",
    "@sanity/client": "^7.14.0",
    "@sanity/image-url": "^2.0.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.2.0",
    "bcryptjs": "^3.0.3",
    "crypto": "^1.0.1",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.25",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.545.0",
    "next": "^15.3.1",
    "nodemon": "^3.1.10",
    "razorpay": "^2.9.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^2.0.5",
    "react-icons": "^5.5.0",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.13.1",
    "resend": "^6.5.2",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "prebuild": "node scripts/validate-runtime-env.js && node scripts/generate-sitemap.js && node scripts/generate-robots.js",
    "build": "rm -rf .next && next build",
    "test": "react-scripts test",
    "check:payment:runtime": "node scripts/diagnose-payment-runtime.js",
    "check:payment:webhooks": "node scripts/check-payment-webhooks.js",
    "test:booking:free-email:cdp": "node scripts/cdp-free-booking-email-check.mjs",
    "check:seo": "node scripts/check-seo.js",
    "check:budgets": "node scripts/check-budgets.js",
    "test:seo:nonjs": "playwright test tests/nonjs-seo.spec.js",
    "test:smoke:routes": "playwright test tests/routes-smoke.spec.js",
    "test:nav:sections": "cross-env BASE_URL=http://127.0.0.1:3001 playwright test tests/section-nav.spec.js",
    "test:nav:chaos": "cross-env BASE_URL=http://127.0.0.1:3001 playwright test tests/nav-chaos.spec.js",
    "audit:phase1:context": "cross-env BASE_URL=http://127.0.0.1:3001 node scripts/phase1-run-context.js",
    "audit:phase1:browser:pre": "node scripts/phase1-browser-hygiene.js",
    "audit:phase1:browser:cleanup": "cross-env APPLY_CLEANUP=1 node scripts/phase1-browser-hygiene.js",
    "audit:phase1:env": "cross-env BASE_URL=http://127.0.0.1:3001 node scripts/phase1-env-determinism.js",
    "audit:phase1:static": "node scripts/phase1-static-safety.js",
    "audit:phase1:route": "cross-env BASE_URL=http://127.0.0.1:3001 node scripts/phase1-route-contract.js",
    "audit:phase1:api": "cross-env BASE_URL=http://127.0.0.1:3001 node scripts/phase1-api-contract.js",
    "audit:phase1:runtime": "cross-env BASE_URL=http://127.0.0.1:3001 node scripts/phase1-runtime-audits.js",
    "audit:phase1:signoff": "cross-env BASE_URL=http://127.0.0.1:3001 node scripts/phase1-signoff.js",
    "audit:mission-critical": "npm run audit:phase1:context && npm run audit:phase1:browser:pre && npm run audit:phase1:env && npm run audit:phase1:static && npm run test:nav:sections -- --reporter=line && npm run test:nav:chaos -- --reporter=line && npm run audit:phase1:route && npm run audit:phase1:api && npm run audit:phase1:runtime && npm run audit:phase1:signoff",
    "audit:mission-critical:x3": "sh -c 'for i in 1 2 3; do echo \"[mission-critical] run $i/3\"; npm run audit:mission-critical || exit 1; done'",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.55.0",
    "@prerenderer/prerenderer": "^1.2.5",
    "@prerenderer/renderer-jsdom": "^1.1.9",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "postcss": "^8.5.6",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.4.18"
  }
}
