{
  "name": "serviport",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@fontsource-variable/roboto-flex": "^5.2.8",
    "@formspree/react": "^3.0.0",
    "@neondatabase/serverless": "^1.1.0",
    "@paypal/react-paypal-js": "^8.9.2",
    "@portabletext/react": "^4.0.3",
    "@sanity/client": "^7.14.0",
    "@sanity/image-url": "^2.0.2",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.110.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "bcryptjs": "^3.0.3",
    "brackets-manager": "^1.11.0",
    "brackets-model": "^1.7.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.25",
    "groq-js": "1.30.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.545.0",
    "next": "15.5.20",
    "nodemon": "^3.1.10",
    "postgres": "^3.4.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^2.0.5",
    "react-icons": "^5.5.0",
    "react-router": "7.18.1",
    "react-router-dom": "7.18.1",
    "resend": "6.17.2",
    "uuid": "11.1.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "prebuild": "node scripts/validate-runtime-env.js && node scripts/generate-sitemap.js && node scripts/generate-robots.js",
    "build": "rm -rf .next && next build",
    "test": "jest",
    "check:payment:runtime": "node scripts/diagnose-payment-runtime.js",
    "check:payment:webhooks": "node scripts/check-payment-webhooks.js",
    "check:payment:stack": "node scripts/check-payment-stack.mjs",
    "check:payment:integrity": "node scripts/check-payment-booking-integrity.mjs",
    "migrate:payment-booking": "node scripts/migrate-payment-booking-repair.mjs",
    "migrate:referral-identities": "node scripts/backfill-referral-identities.mjs",
    "migrate:supabase:dry-run": "node scripts/migrate-sanity-to-supabase.mjs",
    "migrate:supabase:apply": "node scripts/migrate-sanity-to-supabase.mjs --apply",
    "check:supabase:parity": "node scripts/migrate-sanity-to-supabase.mjs --verify-only --reuse-verified-assets",
    "check:supabase:gaps": "node scripts/check-supabase-commerce-gaps.mjs --passes=2",
    "check:supabase:migrations": "node scripts/check-supabase-migrations.mjs",
    "test:supabase:migration:fixtures": "psql \"$SUPABASE_TEST_DATABASE_URL\" -v ON_ERROR_STOP=1 -f supabase/tests/commerce_integrity.sql -f supabase/tests/tourney_auth_integrity.sql -f supabase/tests/social_auth_integrity.sql",
    "test:tourney:postgres17": "node scripts/test-tourney-hardening-postgres.mjs",
    "test:referral:postgres17": "node scripts/test-referral-creator-terms-postgres.mjs",
    "test:referral-social:postgres17": "node scripts/test-referral-social-reclaim-postgres.mjs",
    "test:supabase:document-outbox:postgres17": "node scripts/test-document-mutation-outbox-postgres.mjs",
    "test:backend-integrity:postgres17": "node scripts/test-backend-integrity-postgres.mjs",
    "test:referral-authority:postgres17": "node scripts/test-referral-fallback-authority-postgres.mjs",
    "test:referral-email:postgres17": "node scripts/test-referral-email-dispatch-postgres.mjs",
    "test:referral-integrity:postgres17": "node scripts/test-referral-integrity-hardening-postgres.mjs",
    "repair:tourney:live-drift": "node scripts/tourney-live-drift-repair.mjs",
    "repair:supabase:commerce:dry-run": "node scripts/repair-supabase-commerce-integrity.mjs",
    "repair:supabase:commerce:apply": "node scripts/repair-supabase-commerce-integrity.mjs --apply",
    "repair:referral-accounting:dry-run": "node scripts/repair-referral-accounting.mjs",
    "repair:referral-accounting:apply": "node scripts/repair-referral-accounting.mjs --apply",
    "audit:referral-accounting": "node scripts/repair-referral-accounting.mjs --audit-all",
    "reconcile:referral-mirror:dry-run": "node scripts/reconcile-referral-mirror.mjs",
    "reconcile:referral-mirror:apply": "node scripts/reconcile-referral-mirror.mjs --apply",
    "sync:supabase:commerce:dry-run": "node scripts/sync-sanity-commerce-to-supabase.mjs",
    "sync:supabase:commerce:apply": "node scripts/sync-sanity-commerce-to-supabase.mjs --apply",
    "check:supabase:commerce:parity": "node scripts/sync-sanity-commerce-to-supabase.mjs --verify-only",
    "export:sanity:encrypted": "node scripts/export-sanity-encrypted.mjs",
    "export:supabase:commerce:encrypted": "node scripts/export-supabase-commerce-encrypted.mjs",
    "test:booking:free-email:cdp": "node scripts/cdp-free-booking-email-check.mjs",
    "test:booking:paid-proof:cdp": "node scripts/cdp-paid-checkout-proof.mjs",
    "check:seo": "node scripts/check-seo.js",
    "check:budgets": "node scripts/check-budgets.js",
    "test:seo:nonjs": "playwright test tests/nonjs-seo.spec.js",
    "test:smoke:routes": "playwright test tests/routes-smoke.spec.js",
    "test:nav:sections": "cross-env BASE_URL=http://127.0.0.1:3001 playwright test tests/section-nav.spec.js",
    "test:nav:chaos": "cross-env BASE_URL=http://127.0.0.1:3001 playwright test tests/nav-chaos.spec.js",
    "audit:phase1:context": "cross-env BASE_URL=http://127.0.0.1:3001 node scripts/phase1-run-context.js",
    "audit:phase1:browser:pre": "node scripts/phase1-browser-hygiene.js",
    "audit:phase1:browser:cleanup": "cross-env APPLY_CLEANUP=1 node scripts/phase1-browser-hygiene.js",
    "audit:phase1:env": "cross-env BASE_URL=http://127.0.0.1:3001 node scripts/phase1-env-determinism.js",
    "audit:phase1:static": "node scripts/phase1-static-safety.js",
    "audit:phase1:route": "cross-env BASE_URL=http://127.0.0.1:3001 node scripts/phase1-route-contract.js",
    "audit:phase1:api": "cross-env BASE_URL=http://127.0.0.1:3001 node scripts/phase1-api-contract.js",
    "audit:phase1:runtime": "cross-env BASE_URL=http://127.0.0.1:3001 node scripts/phase1-runtime-audits.js",
    "audit:phase1:signoff": "cross-env BASE_URL=http://127.0.0.1:3001 node scripts/phase1-signoff.js",
    "audit:mission-critical": "npm run audit:phase1:context && npm run audit:phase1:browser:pre && npm run audit:phase1:env && npm run audit:phase1:static && npm run test:nav:sections -- --reporter=line && npm run test:nav:chaos -- --reporter=line && npm run audit:phase1:route && npm run audit:phase1:api && npm run audit:phase1:runtime && npm run audit:phase1:signoff",
    "audit:mission-critical:x3": "sh -c 'for i in 1 2 3; do echo \"[mission-critical] run $i/3\"; npm run audit:mission-critical || exit 1; done'"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@lhci/cli": "0.15.1",
    "@playwright/test": "^1.55.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "postcss": "8.5.10",
    "tailwindcss": "^3.4.18"
  },
  "overrides": {
    "brace-expansion": "1.1.16",
    "cookie": "0.7.2",
    "follow-redirects": "1.16.0",
    "postcss": "$postcss",
    "picomatch": "2.3.2",
    "tmp": "0.2.7",
    "uuid": "11.1.1"
  }
}
